    <string name="help_adaptive_strength_title">Intensidad adaptativa de vibración</string>
    <string name="help_adaptive_strength_description">Controla cuánto escala la vibración según el volumen actual y el contenido grave.</string>
    <string name="help_adaptive_strength_example">Súbelo si las escenas más silenciosas también deben mover el mando. Bájalo si la vibración debe quedarse sobre todo para impactos grandes.</string>
    <string name="help_precise_reaction_title">Reacción precisa</string>
    <string name="help_precise_reaction_description">Se centra en cambios rápidos como disparos, cambios de marcha, impactos y cortes breves dentro de un sonido continuo.</string>
    <string name="help_precise_reaction_example">Activado, hace destacar mejor el retroceso o un cambio de marcha. Desactivado, la vibración será más suave y menos nerviosa.</string>
    <string name="help_bass_follow_title">Seguimiento de bajos</string>
    <string name="help_bass_follow_description">Define qué tan rápido el sistema sigue el cuerpo grave y sostenido del sonido.</string>
    <string name="help_bass_follow_example">Valores altos hacen que el motor o las explosiones entren antes en la vibración. Valores bajos se sienten más suaves y lentos.</string>
    <string name="help_fast_reaction_follow_title">Seguimiento de reacción rápida</string>
    <string name="help_fast_reaction_follow_description">Velocidad de la capa que sigue ráfagas repentinas de energía y cambios rápidos.</string>
    <string name="help_fast_reaction_follow_example">Más alto reacciona más rápido a disparos y golpes cortos. Más bajo mantiene la respuesta más tranquila.</string>
    <string name="help_slow_reaction_follow_title">Seguimiento de reacción lenta</string>
    <string name="help_slow_reaction_follow_description">Velocidad de la capa de referencia lenta con la que se compara la reacción rápida.</string>
    <string name="help_slow_reaction_follow_example">Valores bajos separan mejor los eventos bruscos del ruido de fondo. Valores altos reducen ese contraste.</string>
    <string name="help_adaptive_floor_title">Suelo adaptativo</string>
    <string name="help_adaptive_floor_description">Impulso adaptativo mínimo. Decide cuánta vibración sigue viva en escenas más débiles.</string>
    <string name="help_adaptive_floor_example">Súbelo para mantener presencia en juegos silenciosos. Bájalo para que las secciones quietas desaparezcan con más facilidad.</string>
    <string name="help_adaptive_ceiling_title">Techo adaptativo</string>
    <string name="help_adaptive_ceiling_description">Impulso adaptativo máximo. Limita cuánto se pueden reforzar los momentos más fuertes y relevantes.</string>
    <string name="help_adaptive_ceiling_example">Valores altos hacen que los sonidos importantes golpeen más. Demasiado alto puede volver fuertes demasiadas cosas.</string>
    <string name="help_low_threshold_title">Umbral de bajos</string>
    <string name="help_low_threshold_description">Umbral para contenido grave sostenido. Por encima de esto, la señal cuenta como bajo fuerte y estable.</string>
    <string name="help_low_threshold_example">Bájalo para reaccionar antes a sonidos graves de fondo. Súbelo para quedarte solo con las partes con más cuerpo.</string>
    <string name="help_transient_threshold_title">Umbral transitorio</string>
    <string name="help_transient_threshold_description">Umbral para eventos rápidos. Por encima de esto, la señal se trata como un golpe o cambio notable.</string>
    <string name="help_transient_threshold_example">Valores bajos captan hasta toques ligeros. Valores altos dejan pasar sobre todo disparos grandes e impactos duros.</string>
    <string name="help_strong_low_mix_title">Mezcla de bajos fuertes</string>
    <string name="help_strong_low_mix_description">Cuánto bajo fuerte y estable se mezcla en la vibración final.</string>
    <string name="help_strong_low_mix_example">En carreras o explosiones esto da cuerpo. Demasiado alto puede hacer que la vibración se sienta siempre pesada.</string>
    <string name="help_transient_low_mix_title">Mezcla de bajos transitorios</string>
    <string name="help_transient_low_mix_description">Cantidad de mezcla para contenido grave cambiante de intensidad media.</string>
    <string name="help_transient_low_mix_example">Úsalo para decidir cuánto debe permanecer en la vibración el sonido de un motor en movimiento o el ruido de acción.</string>
    <string name="help_quiet_low_mix_title">Mezcla de bajos suaves</string>
    <string name="help_quiet_low_mix_description">Cuánto contenido grave muy bajo o apenas detectable contribuye a la vibración.</string>
    <string name="help_quiet_low_mix_example">Útil en presets de juegos tranquilos para que los momentos silenciosos no queden vacíos. Demasiado alto puede crear vibración de fondo constante.</string>
    <string name="help_precise_punch_title">Golpe preciso</string>
    <string name="help_precise_punch_description">Fuerza de impacto para eventos rápidos y claramente separados.</string>
    <string name="help_precise_punch_example">En un FPS puede resaltar disparos, retroceso, clics de recarga o impactos duros. Los valores altos pueden ser agresivos.</string>
    <string name="help_soft_punch_title">Golpe suave</string>
    <string name="help_soft_punch_description">Fuerza de impacto para transiciones más suaves y menos bruscas.</string>
    <string name="help_soft_punch_example">Súbelo si también quieres notar pequeños movimientos rítmicos. Bájalo si el sistema debe centrarse en eventos más pesados.</string>
    <string name="help_punch_polarity_scale_title">Escala de polaridad del golpe</string>
    <string name="help_punch_polarity_scale_description">Peso total del pico de reacción rápida dentro de la vibración final.</string>
    <string name="help_punch_polarity_scale_example">Valores altos se sienten más vivos y elásticos. Valores bajos se sienten más apagados y suaves.</string>
    <string name="help_soft_clip_title">Recorte suave</string>
    <string name="help_soft_clip_description">Cuánto se suaviza la señal final de vibración antes de que el pico sea demasiado fuerte.</string>
    <string name="help_soft_clip_example">Valores altos mantienen más crudeza y dinámica, pero con más riesgo. Valores bajos controlan mejor los picos demasiado fuertes.</string>
