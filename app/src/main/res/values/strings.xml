    <string name="help_adaptive_strength_title">Adaptive vibration strength</string>
    <string name="help_adaptive_strength_description">Controls how strongly the rumble scales with the current loudness and low-frequency content.</string>
    <string name="help_adaptive_strength_example">Raise it if quieter scenes should still move the controller. Lower it if rumble should stay mostly for bigger hits.</string>
    <string name="help_precise_reaction_title">Precise reaction</string>
    <string name="help_precise_reaction_description">Focuses on fast changes like shots, shifts, impacts, and brief drops inside a continuous sound.</string>
    <string name="help_precise_reaction_example">When enabled, recoil or a gear shift pops out more clearly. When disabled, rumble stays smoother and less twitchy.</string>
    <string name="help_bass_follow_title">Bass follow</string>
    <string name="help_bass_follow_description">Sets how quickly the system follows the steady low-frequency body of the sound.</string>
    <string name="help_bass_follow_example">Higher values make engine hum or explosion body settle into rumble faster. Lower values feel softer and slower.</string>
    <string name="help_fast_reaction_follow_title">Fast reaction follow</string>
    <string name="help_fast_reaction_follow_description">Speed of the layer that tracks sudden energy bursts and quick changes.</string>
    <string name="help_fast_reaction_follow_example">Higher values react faster to short shots and hits. Lower values keep the response calmer.</string>
    <string name="help_slow_reaction_follow_title">Slow reaction follow</string>
    <string name="help_slow_reaction_follow_description">Speed of the slower reference layer that the fast reaction layer is compared against.</string>
    <string name="help_slow_reaction_follow_example">Lower values separate sharp events from background noise more clearly. Higher values reduce that contrast.</string>
    <string name="help_adaptive_floor_title">Adaptive floor</string>
    <string name="help_adaptive_floor_description">Minimum adaptive boost. It decides how much rumble stays alive in weaker scenes.</string>
    <string name="help_adaptive_floor_example">Raise it to keep a little presence in quiet games. Lower it to let quiet sections fade away more easily.</string>
    <string name="help_adaptive_ceiling_title">Adaptive ceiling</string>
    <string name="help_adaptive_ceiling_description">Maximum adaptive boost. It limits how hard louder, relevant moments can be pushed.</string>
    <string name="help_adaptive_ceiling_example">Higher values make important sounds hit harder. Too high and too many things may feel strong.</string>
    <string name="help_low_threshold_title">Low threshold</string>
    <string name="help_low_threshold_description">Threshold for steady low-frequency content. Above this, the signal counts as strong sustained bass.</string>
    <string name="help_low_threshold_example">Lower it to react sooner to deeper background sounds. Raise it to keep only the really weighty parts.</string>
    <string name="help_transient_threshold_title">Transient threshold</string>
    <string name="help_transient_threshold_description">Threshold for quick events. Above this, the signal is treated as a notable hit or shift.</string>
    <string name="help_transient_threshold_example">Lower values catch lighter taps too. Higher values mostly let through bigger shots and harder impacts.</string>
    <string name="help_strong_low_mix_title">Strong low mix</string>
    <string name="help_strong_low_mix_description">How much strong, stable bass is mixed into the final rumble.</string>
    <string name="help_strong_low_mix_example">In racing games or explosions this gives the body. Too high and the rumble can feel constantly overweight.</string>
    <string name="help_transient_low_mix_title">Transient low mix</string>
    <string name="help_transient_low_mix_description">Mix amount for mid-strength but changing low-frequency content.</string>
    <string name="help_transient_low_mix_example">Use this to decide how much moving engine sound or action noise should stay present in the rumble.</string>
    <string name="help_quiet_low_mix_title">Quiet low mix</string>
    <string name="help_quiet_low_mix_description">How much very quiet or barely detectable low content contributes to rumble.</string>
    <string name="help_quiet_low_mix_example">Useful in quiet-game presets so silent moments do not go completely empty. Too high can create constant background rumble.</string>
    <string name="help_precise_punch_title">Precise punch</string>
    <string name="help_precise_punch_description">Impact strength for fast, clearly separated events.</string>
    <string name="help_precise_punch_example">In an FPS this can highlight shots, recoil, reload clicks, or a hard impact. High values can get aggressive.</string>
    <string name="help_soft_punch_title">Soft punch</string>
    <string name="help_soft_punch_description">Impact strength for softer, less sharp transitions.</string>
    <string name="help_soft_punch_example">Raise it if smaller rhythmic movement should be felt more. Lower it if the system should focus on the heavier events.</string>
    <string name="help_punch_polarity_scale_title">Punch polarity scale</string>
    <string name="help_punch_polarity_scale_description">Overall weight of the fast reaction peak inside the final rumble.</string>
    <string name="help_punch_polarity_scale_example">Higher values feel livelier and bouncier. Lower values feel more muted and smooth.</string>
    <string name="help_soft_clip_title">Soft clip</string>
    <string name="help_soft_clip_description">How much the final rumble signal is smoothed before it spikes too hard.</string>
    <string name="help_soft_clip_example">Higher values keep things rawer and more dynamic, but riskier. Lower values tame overly strong peaks more firmly.</string>
